{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            to_jsonb(u) \"user: Json<User>\",\n            su.role AS \"role: ServerRole\",\n            su.created_at,\n            su.updated_at\n        FROM users u\n        JOIN server_users su ON u.name = su.user_name AND u.host = su.user_host\n        WHERE su.server_id = $1\n        ORDER BY u.name, u.host\n        ",
